<?xml version="1.0" encoding="utf-8"?>
<!-- Cleartext HTTP allowed for local dev: emulator 10.0.2.2 -> host localhost:5000 -->
<network-security-config xmlns:tools="http://schemas.android.com/tools">
    <!-- Primary fix: permit HTTP for development API (required on API 28+ for cleartext) -->
    <base-config
        cleartextTrafficPermitted="true"
        tools:ignore="InsecureBaseConfiguration">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
    <!-- Explicit domains (backup for OEMs that scope cleartext oddly) -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
        <domain includeSubdomains="true">10.0.2.2</domain>
    </domain-config>
</network-security-config>
